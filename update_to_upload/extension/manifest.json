{
  "manifest_version": 3,
  "name": "BulkApply Extension",
  "version": "1.1",
  "description": "Scrape jobs from LinkedIn, Indeed, Naukri, Glassdoor, Greenhouse and Lever, and save them to BulkApply. Includes a LinkedIn Easy Apply auto-fill assist.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8080/*",
    "http://localhost:8080/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://*.naukri.com/*",
        "*://*.glassdoor.*/*",
        "*://boards.greenhouse.io/*",
        "*://job-boards.greenhouse.io/*",
        "*://jobs.lever.co/*"
      ],
      "js": ["content.js"]
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["easyapply.js"]
    }
  ]
}
